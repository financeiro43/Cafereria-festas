rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based access helpers
    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'financeiro@modeloalpha.com.br' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isVendor() {
      return isVerified() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'balance', 'role', 'qrCode']) &&
             data.keys().size() >= 6 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.balance is number &&
             data.role in ['student', 'vendor', 'admin', 'recharge'] &&
             data.qrCode is string && data.qrCode.size() <= 128;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'status', 'timestamp']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.amount is number &&
             data.type in ['credit', 'debit'] &&
             data.description is string && data.description.size() <= 200 &&
             data.status in ['completed', 'pending', 'failed'] &&
             data.timestamp == request.time;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['studentId', 'stallId', 'items', 'total', 'status', 'timestamp']) &&
             data.studentId is string && data.studentId.size() <= 128 &&
             data.stallId is string && data.stallId.size() <= 128 &&
             data.items is list && data.items.size() <= 50 &&
             data.total is number &&
             data.status in ['pending', 'delivered', 'cancelled'] &&
             data.timestamp == request.time;
    }

    // --- Collection Routes ---

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isVendor());
      allow list: if isAdmin();
      
      allow create: if isVerified() && isValidUser(incoming()) && (
        request.auth.uid == userId || isAdmin()
      );
      
      allow update: if isVerified() && (
        isAdmin() ||
        // Profile update (name/photo only)
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL'])) ||
        // Balance update (MUST be accompanied by transaction, but rules can't enforce batch atomicity across collections without existsAfter which is tricky here)
        // We'll allow vendor/admin to update balance if it's a legitimate sale/recharge
        (isVendor() || isAdmin())
      );
    }

    // TRANSACTIONS
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isVerified() && isValidTransaction(incoming()) && (
        incoming().userId == request.auth.uid || isVendor() || isAdmin()
      );
      
      allow update: if isVerified() && (
        isAdmin() ||
        // Users can only update status from pending to completed (e.g. after payment callback)
        (resource.data.userId == request.auth.uid && 
         resource.data.status == 'pending' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }

    // ORDERS
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isVendor() || isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isVendor() || isAdmin());
      
      allow create: if isVerified() && isValidOrder(incoming()) && incoming().studentId == request.auth.uid;
      
      allow update: if isVerified() && (
        isAdmin() ||
        // Vendor delivering order
        (isVendor() && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    // STALLS
    match /stalls/{stallId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isVendor();
    }

    // CONSUMPTION
    match /consumption/{consumptionId} {
       allow read: if isAdmin() || isVendor() || (isSignedIn() && resource.data.studentId == request.auth.uid);
       allow create: if isVerified() && (isVendor() || isAdmin());
    }

    // WITHDRAWALS
    match /withdrawals/{withdrawalId} {
      allow read, write: if isAdmin();
    }
  }
}
