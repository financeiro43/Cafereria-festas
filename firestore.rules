rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to get user data safely
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'financeiro@modeloalpha.com.br') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isVendor() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Students can read their own profile, Vendors/Admins can read any profile
      allow get: if isSignedIn() && (request.auth.uid == userId || isVendor() || isAdmin());
      // Admins can list all users
      allow list: if isAdmin();
      // Users create their own profile on first login, or Admins pre-register
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Profile updates
      allow update: if isSignedIn() && (request.auth.uid == userId || isVendor() || isAdmin());
    }

    // --- Transactions Collection ---
    match /transactions/{transactionId} {
      // Users can see their own history, Admins see all
      allow read: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      
      // Creation logic
      allow create: if isSignedIn() && (
        // User creating a pending recharge
        (request.resource.data.userId == request.auth.uid && request.resource.data.type == 'credit' && request.resource.data.status == 'pending') ||
        // Vendor recording a purchase
        (isVendor() && request.resource.data.type == 'debit') ||
        // Admin
        isAdmin()
      );

      // Allow users to update their own pending transactions to completed (Simulation purposes)
      allow update: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid && resource.data.status == 'pending') ||
        isAdmin()
      );
    }

    // --- Consumption Collection ---
    match /consumption/{consumptionId} {
      allow read: if isSignedIn() && (
        (resource != null && resource.data.studentId == request.auth.uid) || 
        isVendor() || 
        isAdmin()
      );
      allow create: if isVendor() || isAdmin();
    }

    // --- Stalls Collection ---
    match /stalls/{stallId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Products Collection ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isVendor() && request.resource.data.vendorId == getUserData().vendorId);
    }

    // --- Withdrawals Collection ---
    match /withdrawals/{withdrawalId} {
      allow read, write: if isAdmin();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.studentId || isVendor() || isAdmin());
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if isSignedIn() && (isVendor() || isAdmin());
    }
  }
}
