rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email == 'financeiro@modeloalpha.com.br' || 
        request.auth.token.firebase.sign_in_provider == 'password'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based access helpers
    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email.lower() == 'financeiro@modeloalpha.com.br') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isVendor() {
      return isSignedIn() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor')
      );
    }

    function isRecharge() {
      return isSignedIn() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'recharge')
      );
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'balance', 'role', 'qrCode']) &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.balance is number &&
             data.role in ['admin', 'vendor', 'recharge', 'student'] &&
             data.qrCode is string && data.qrCode.size() <= 256;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'status', 'timestamp']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.amount is number &&
             data.type in ['credit', 'debit'] &&
             data.status in ['completed', 'pending', 'failed'] &&
             data.timestamp == request.time;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['studentId', 'stallId', 'items', 'total', 'status', 'timestamp']) &&
             data.studentId is string && data.studentId.size() <= 128 &&
             data.stallId is string && data.stallId.size() <= 128 &&
             data.items is list && data.items.size() <= 100 &&
             data.total is number &&
             data.status in ['pending', 'delivered', 'cancelled'] &&
             data.timestamp == request.time;
    }

    function isValidConsumption(data) {
      return data.keys().hasAll(['studentId', 'amount', 'items', 'timestamp']) &&
             data.studentId is string && data.studentId.size() <= 128 &&
             data.amount is number &&
             data.items is list && data.items.size() <= 100 &&
             data.timestamp == request.time;
    }

    // --- Collection Routes ---

    // SETTINGS
    match /settings/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // USERS
    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn();
      
      allow create: if isUser(userId) || isAdmin();
      
      allow update: if isAdmin() ||
        (incoming()._backendSecret == 'FESTA_PASS_SRV_2026_SECRET') ||
        (isUser(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'fcmToken', 'associatedUids'])) ||
        (isVendor() && incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'spentToday', 'lastSpentDate'])) ||
        (isRecharge() && incoming().diff(existing()).affectedKeys().hasOnly(['balance'])) ||
        (
          isSignedIn() && 
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          ('associatedUids' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.associatedUids.hasAny([userId])) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['dailyLimit', 'transactionLimit', 'spentToday', 'lastSpentDate', 'balance', 'balanceType', 'parentUid'])
        );

      allow delete: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // TRANSACTIONS
    match /transactions/{transactionId} {
      allow get: if true;
      allow list: if isSignedIn() && (isAdmin() || isVendor() || isRecharge() || resource.data.userId == request.auth.uid);
      
      allow create: if (isVerified() && isValidTransaction(incoming()) && (
        incoming().userId == request.auth.uid || isVendor() || isAdmin() || isRecharge()
      )) || (incoming()._backendSecret == 'FESTA_PASS_SRV_2026_SECRET');
      
      allow update: if isAdmin() || (incoming()._backendSecret == 'FESTA_PASS_SRV_2026_SECRET') || (
        isVerified() && (
          // Users can only update status from pending to completed (e.g. after payment callback)
          (resource.data.userId == request.auth.uid && 
           resource.data.status == 'pending' && 
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        )
      );
    }

    // ORDERS
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || 
                                     resource.data.stallId in (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.vendorIds || []) || 
                                     isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || 
                                      isAdmin() ||
                                      (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor'));
      
      allow create: if isSignedIn() && isValidOrder(incoming()) && incoming().studentId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        // Vendor delivering order
        (isVendor() && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
    }

    // STALLS
    match /stalls/{stallId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isVendor();
    }

    // CONSUMPTION
    match /consumption/{consumptionId} {
       allow read: if isAdmin() || isVendor() || (isSignedIn() && resource.data.studentId == request.auth.uid);
       allow create: if isVerified() && isValidConsumption(incoming()) && (isVendor() || isAdmin());
    }

    // WITHDRAWALS
    match /withdrawals/{withdrawalId} {
      allow read, write: if isAdmin();
    }
  }
}
